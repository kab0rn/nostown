{
  "name": "nos-town",
  "version": "0.1.0",
  "description": "NOSTown — bridge-first swarm consensus runtime for Gas City",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "nt": "./scripts/nt.sh",
    "nos": "./scripts/nos.sh"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:unit": "jest tests/unit/",
    "test:integration": "jest tests/integration/",
    "typecheck": "tsc --noEmit",
    "smoke:gascity": "scripts/smoke-gascity-bridge.sh --read-only",
    "test:ci": "npm run typecheck && npm run build && npm test -- --runInBand --silent && (cd cmd/nt && go test ./...)"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@noble/ed25519": "^2.1.0",
    "@opentelemetry/api": "^1.9.1",
    "better-sqlite3": "^12.0.0",
    "groq-sdk": "^1.0.0",
    "node-cron": "^4.2.1",
    "proper-lockfile": "^4.1.2",
    "uuid": "^11.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
