# NOS Town — Environment Configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key (required for all agent inference)
GROQ_API_KEY=gsk_...

# Active rig name (the project workspace)
NOS_RIG=my-project

# Directory containing per-role Ed25519 key pairs
# Files: {sender_id}.key (private hex) and {sender_id}.pub (public hex)
NOS_ROLE_KEY_DIR=./keys

# ── Optional ──────────────────────────────────────────────────────────────────

# Cluster-local transport MAC secret (optional — supplements Ed25519 sender auth)
# NOS_CONVOY_SECRET=your-cluster-secret-here

# Quarantine directory for rejected convoys
# NOS_QUARANTINE_DIR=nos/quarantine

# Rigs root directory
# NOS_RIGS_ROOT=rigs

# Safeguard pool size (min 2 in dev, 4 in prod)
# SAFEGUARD_POOL_SIZE=2

# Path to JSONL file with custom security scan rules (default: src/hardening/safeguard-rules.jsonl)
# Each line: {"id":"...","name":"...","severity":"critical|high|medium","pattern":"regex","description":"..."}
# NOS_SAFEGUARD_RULES=src/hardening/safeguard-rules.jsonl

# Log verbosity: debug, info, warn (default: info)
# NOS_LOG_LEVEL=info

# Historian cron schedule (default: 0 2 * * * — 2am nightly)
# Historian runs mine KG patterns from Ledger. Can be invoked externally or via cron.
# HISTORIAN_CRON=0 2 * * *

# Ollama fallback URL (optional — activates Tier B local fallback)
# OLLAMA_URL=http://localhost:11434
